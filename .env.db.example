# Copy this file to .env.local (or export vars in your shell) and fill values.
# Read-only PostgreSQL connection string from Supabase.
DB_READONLY_URL=postgresql://readonly_user:readonly_password@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Optional schema name (default: public)
DB_SCHEMA=public

# Optional sample size per table (default: 5)
DB_SAMPLE_LIMIT=5
